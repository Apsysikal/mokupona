{
  "name": "mokupona-4755",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#prisma/*": "./prisma/*.ts"
  },
  "scripts": {
    "build": "prisma generate && react-router build",
    "dev": "node ./mocks/index.js & react-router dev --host",
    "format": "prettier --write .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "start": "react-router-serve ./build/server/index.js",
    "start:mocks": "node ./mocks/index.js & react-router-serve ./build/server/index.js",
    "test": "vitest",
    "test:e2e:dev": "start-server-and-test dev http://localhost:3000 \"npx cypress open\"",
    "pretest:e2e:run": "npm run build",
    "test:e2e:ci": "cross-env PORT=8811 start-server-and-test start:mocks http://localhost:8811 \"npx cypress run\"",
    "test:e2e:run": "cross-env PORT=8811 start-server-and-test start:mocks http://localhost:8811 \"npx cypress run\"",
    "typecheck": "prisma generate &&react-router typegen && tsc && tsc -p cypress",
    "validate": "run-p \"test -- --run\" lint typecheck test:e2e:run",
    "prisma:studio": "prisma studio",
    "optimize:images": "tsx app/optimize-images.ts"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@conform-to/react": "^1.18.0",
    "@conform-to/zod": "^1.18.0",
    "@mdx-js/rollup": "^3.1.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.14.0",
    "@remix-run/file-storage": "^0.13.3",
    "@remix-run/form-data-parser": "^0.16.0",
    "@remix-run/lazy-file": "^5.0.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "isbot": "^5.1.37",
    "prisma": "^7.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tiny-invariant": "^1.3.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "binode": "^1.0.5",
    "cookie": "^1.1.1",
    "cross-env": "^10.1.0",
    "cypress": "^15.13.1",
    "eslint": "^10.2.0",
    "eslint-plugin-cypress": "^6.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "msw": "^2.13.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4.2.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.50.0"
